// Multi-tenant photo-frame platform schema.
// Each Tenant = a car dealership ("concessionária") with its own visual identity.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String

  // Visual identity / branding
  primaryColor   String  @default("#0ea5e9")
  secondaryColor String  @default("#0b1220")
  accentColor    String  @default("#f59e0b")
  textColor      String  @default("#ffffff")
  fontFamily     String  @default("Inter")
  logoUrl        String?

  // Contact info shown on the marketing frames
  phone   String?
  website String?
  address String?
  tagline String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  frames   Frame[]
  artworks Artwork[]
  studios  Studio[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("OWNER") // OWNER | MEMBER
  isSuperAdmin Boolean  @default(false)   // platform owner: manages all tenants

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  artworks Artwork[]

  createdAt DateTime @default(now())
}

model Frame {
  id       String  @id @default(cuid())
  name     String
  imageUrl String  // PNG overlay with a transparent "window" for the photo
  width    Int     @default(1080)
  height   Int     @default(1080)

  // Optional slot rectangle (where the photo should sit), as fractions 0..1
  slotX Float @default(0)
  slotY Float @default(0)
  slotW Float @default(1)
  slotH Float @default(1)

  source String @default("IMPORTED") // IMPORTED | GENERATED

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  artworks Artwork[]

  createdAt DateTime @default(now())
}

// A self-contained HTML "studio" exported from Claude Design and imported by a
// tenant. Served inside the platform (in an iframe) behind login.
model Studio {
  id      String @id @default(cuid())
  name    String
  htmlUrl String // URL of the uploaded HTML file (Blob in prod, /uploads in dev)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Artwork {
  id       String @id @default(cuid())
  imageUrl String

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  frameId String?
  frame   Frame?  @relation(fields: [frameId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}
