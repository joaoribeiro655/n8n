# Banco de dados (SQLite por padrão; troque para Postgres em produção se quiser)
DATABASE_URL="file:./dev.db"

# Segredo para assinar a sessão (JWT). Em produção use um valor longo e aleatório:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="dev-secret-change-me-in-production-please-32chars-min"

# E-mail promovido a super-admin da plataforma automaticamente ao fazer login.
SUPER_ADMIN_EMAIL="seu-email@dominio.com"
