# Banco de dados PostgreSQL.
# Em produção (Vercel) use o endereço do Neon/Vercel Postgres.
# Exemplo Neon: postgresql://user:senha@ep-xxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/moldura?schema=public"

# Segredo para assinar a sessão (login). Gere um valor longo e aleatório:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="dev-secret-change-me-in-production-please-32chars-min"

# E-mail promovido a super-admin da plataforma automaticamente ao fazer login.
SUPER_ADMIN_EMAIL="seu-email@dominio.com"

# Guardador de imagens na nuvem (Vercel Blob).
# A Vercel preenche isso sozinha quando você ativa o Blob no painel.
# Se ficar vazio, as imagens são salvas localmente (apenas para desenvolvimento).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"
